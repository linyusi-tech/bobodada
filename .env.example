# Copy this file to .env.local for local development.
# Add the same variables to your online serverless environment.

FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# This is the Feishu wiki document that receives birthday wishes.
FEISHU_WISH_DOC_URL=https://your-workspace.feishu.cn/wiki/your_wiki_token

# Optional: use these only if wiki lookup fails or you already know the Docx token.
# FEISHU_WISH_WIKI_TOKEN=your_wiki_token
# FEISHU_WISH_DOC_TOKEN=
# FEISHU_WISH_PARENT_BLOCK_ID=

# Comma-separated origins allowed to call /api/wishes.
WISH_ALLOWED_ORIGINS=https://bobodada.cn,https://www.bobodada.cn,http://127.0.0.1:8036,http://localhost:8036,http://127.0.0.1:8037,http://localhost:8037
